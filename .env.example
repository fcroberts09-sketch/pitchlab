# Anthropic API Key
# Get yours at https://console.anthropic.com/settings/keys
# Set to "mock" (or leave empty) to run locally without an API key — returns realistic sample data
ANTHROPIC_API_KEY=mock

# Optional: Override the model used for analysis
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Optional: Max requests per minute per IP (default: 10)
# RATE_LIMIT_PER_MINUTE=10
